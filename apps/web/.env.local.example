# Market Data Service endpoints
# Copy this file to .env.local and fill in real values after Terraform apply

# WebSocket API Gateway endpoint (from: terraform output ws_api_endpoint)
NEXT_PUBLIC_WS_URL=wss://XXXXXXXXXX.execute-api.ap-northeast-2.amazonaws.com/prod

# REST API (API Gateway HTTP or ECS load balancer URL)
NEXT_PUBLIC_MARKET_API_URL=https://market-api.your-domain.com

# Identity Service (existing — should already be set)
NEXT_PUBLIC_IDENTITY_API_URL=https://identity.your-domain.com
