# ─── Per-domain API endpoints (each maps to its own AWS account) ──────────────
# Identity domain (identity-{env} account)
NEXT_PUBLIC_IDENTITY_API_URL=https://api.identity.cryptotrade.internal

# SpotTrading domain (spottrading-{env} account)
NEXT_PUBLIC_SPOT_API_URL=https://api.spot.cryptotrade.internal

# FuturesTrading domain (futurestrading-{env} account)
NEXT_PUBLIC_FUTURES_API_URL=https://api.futures.cryptotrade.internal

# Finance domain — Deposit + Withdrawal share one Finance account
NEXT_PUBLIC_FINANCE_API_URL=https://api.finance.cryptotrade.internal

# ─── WebSocket (MarketData domain — marketdata-{env} account) ────────────────
NEXT_PUBLIC_WS_URL=wss://ws.marketdata.cryptotrade.internal

# ─── Environment ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENV=production
